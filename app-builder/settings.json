{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ROLE": "app-builder",
    "ROLE_LABEL": "App Builder"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npx*)",
      "Bash(node*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(echo*)",
      "Bash(touch*)",
      "Bash(which*)",
      "Bash(pwd*)",
      "Bash(dev-update*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(sudo*)",
      "Bash(chmod 777*)",
      "Bash(curl*|*bash*)",
      "Bash(wget*|*bash*)"
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "excludeDefault": true,
    "tips": [
      "Do One Thing. Ship fast. No bloat.",
      "Run /compact when approaching 70% context.",
      "Run /handoff to save state before ending.",
      "Functions < 30 lines. Files < 300 lines.",
      "Read Distilled/ for project context."
    ]
  }
}
