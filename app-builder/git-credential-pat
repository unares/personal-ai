#!/bin/sh
# Git credential helper — returns GITHUB_TOKEN from environment.
# Baked into App Builder Docker image. Token passed via docker run -e.
if [ "$1" = "get" ]; then
  test -n "$GITHUB_TOKEN" || exit 0
  echo "protocol=https"
  echo "host=github.com"
  echo "username=x-access-token"
  echo "password=$GITHUB_TOKEN"
fi
