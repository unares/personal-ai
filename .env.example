# Personal AI v0.4 — Environment Variables
# Copy to .env and fill in your keys:
#   cp .env.example .env

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google AI Studio key for Gemini 3.1 Pro (hybrid routing)
GEMINI_API_KEY=AIza...

# Optional: LiteLLM proxy master key (any string, used for auth)
LITELLM_MASTER_KEY=sk-litellm-local

# Optional: LiteLLM proxy URL (set automatically by docker-compose)
LITELLM_BASE_URL=http://litellm-proxy:4000

# Optional: Enable hybrid LLM routing (Gemini for planning, Claude for tools)
HYBRID_ENABLED=true
