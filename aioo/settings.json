{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ROLE": "aioo",
    "ROLE_LABEL": "AI Operating Officer"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo*)",
      "Bash(curl*|*bash*)",
      "Bash(wget*|*bash*)",
      "Bash(docker run*--privileged*)"
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "excludeDefault": true,
    "tips": [
      "Do One Thing. Drive execution.",
      "Read NORTHSTAR.md first — always.",
      "Log decisions to /vault/Logs/aioo.log",
      "Spawn App Builders for building, not yourself.",
      "Run /compact at 70% context."
    ]
  }
}
