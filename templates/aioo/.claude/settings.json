{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "Edit(**)",
      "Write(**)",
      "Read(**)",
      "WebSearch",
      "WebFetch(*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/compact-northstar.sh"
          }
        ]
      }
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": [
    "AIOO: update NORTHSTAR.md and the summary auto-propagates to Clark",
    "Run /compact when approaching 70% context",
    "Run /handoff before ending a session",
    "Seed mvp-builder NORTHSTAR.md + SCOPE.md before spawning",
    "Log cost events to chronicle.db: event_type='agent_cost'"
  ]
}
