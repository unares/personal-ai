{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ROLE": "non-technical",
    "ROLE_LABEL": "Non-Technical",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(echo*)",
      "Bash(date*)",
      "Bash(pwd*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm*)",
      "Bash(sudo*)",
      "Bash(docker*)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git reset*)"
    ]
  }
}
