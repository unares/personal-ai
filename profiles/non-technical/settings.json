{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "claudeMdExcludes": [
    "**/services/nanoclaw-paw/**"
  ],
  "env": {
    "ROLE": "non-technical",
    "ROLE_LABEL": "Non-Technical",
    "ENABLE_LSP_TOOL": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./setup/hooks/session-start.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./setup/hooks/session-stop.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./setup/sync-memory.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(echo*)",
      "Bash(date*)",
      "Bash(pwd*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm*)",
      "Bash(sudo*)",
      "Bash(docker*)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git reset*)"
    ]
  }
}
